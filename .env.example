# GymRebel — environment variables
# Kopieer dit bestand naar .env (en/of .env.local) en vul de waarden in.
# .env wordt NIET gecommit (zie .gitignore).

# --- Database (PostgreSQL, EU regio: Neon / Vercel Postgres / Supabase) ---
# DATABASE_URL: gepoolde connection string (gebruikt door de app at runtime).
DATABASE_URL="postgresql://user:password@host:5432/gymrebel?schema=public"
# DIRECT_URL: directe (niet-gepoolde) connection string voor migraties.
# Bij Neon/Vercel: de niet-pooler host. Lokaal mag dit gelijk zijn aan DATABASE_URL.
DIRECT_URL="postgresql://user:password@host:5432/gymrebel?schema=public"

# --- Auth (NextAuth.js v5 / Auth.js) ---
# Genereer met: openssl rand -base64 32
NEXTAUTH_SECRET="vervang-mij-met-een-random-secret"
NEXTAUTH_URL="http://localhost:3001"
# Auth.js v5 leest AUTH_SECRET / AUTH_URL (mogen dezelfde waarden zijn).
AUTH_SECRET="vervang-mij-met-een-random-secret"
AUTH_URL="http://localhost:3001"

# --- Media storage (Vercel Blob) ---
BLOB_READ_WRITE_TOKEN=""

# --- E-mail (Microsoft Graph, app-only) voor uitnodigingsmails ---
# App-registratie met APPLICATION-permissie Mail.Send (admin consent vereist).
# Zonder deze vars valt de uitnodigingsmail terug op de server-console (dev).
GRAPH_TENANT_ID=""
GRAPH_CLIENT_ID=""
GRAPH_CLIENT_SECRET=""
# Mailbox (UPN) waarvandaan verstuurd wordt, bv. noreply@jouwdomein.nl
GRAPH_SENDER=""

# --- AI-assistent (prompt 11) — omschakelbaar tussen Claude en OpenAI ---
# Zonder key degradeert de assistent netjes (geen antwoord). Per tenant aan/uit
# via owner-instellingen (Tenant.aiEnabled).
# Provider: "anthropic" (Claude, EU data-residency via inference_geo) of "openai".
AI_PROVIDER="anthropic"
# Anthropic Claude
ANTHROPIC_API_KEY=""
# Default claude-opus-4-8; goedkoper/sneller: claude-haiku-4-5.
ANTHROPIC_MODEL="claude-opus-4-8"
# OpenAI / ChatGPT (alleen nodig bij AI_PROVIDER="openai")
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o"
# Optioneel: EU/Azure-OpenAI-endpoint voor data-residency (anders standaard US).
OPENAI_BASE_URL=""

# --- Exercises-dataset import (scripts/upload-media.mjs + scripts/import-exercises.mjs) ---
# Azure Blob Storage connection string (Portal → Storage account → Access keys).
AZURE_STORAGE_CONNECTION_STRING="DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net"
# Containernaam waarin de media komt (wordt aangemaakt met anonymous blob-read).
AZURE_BLOB_CONTAINER="exercise-media"
# Optioneel: overschrijf de afgeleide basis-URL (anders afgeleid uit account + container).
# AZURE_BLOB_BASE_URL="https://<account>.blob.core.windows.net/exercise-media"
# Lokale map met de dataset (data/exercises.json, images/, videos/).
DATASET_DIR="c:/Users/ducop/Desktop/exercises-dataset-main/exercises-dataset-main"

# --- Vertaling (Azure Translator, EU-regio) — voor en→nl bij import ---
# Portal → Translator-resource → Keys and Endpoint. Endpoint mag de globale waarde blijven;
# de region-header (AZURE_TRANSLATOR_REGION) bepaalt de EU-routing. Optioneel: zonder key
# importeert het script zonder nl-vertaling (alleen en/es/it/tr).
AZURE_TRANSLATOR_KEY=""
AZURE_TRANSLATOR_ENDPOINT="https://api.cognitive.microsofttranslator.com"
AZURE_TRANSLATOR_REGION="germanywestcentral"

# --- SSO / OAuth (optioneel) — login & verbonden accounts ---
# Alleen toegevoegd als ID+SECRET gezet zijn; gebruikers worden gekoppeld op
# e-mailadres aan een bestaand tenant-account (invite-only blijft).
# Google: console.cloud.google.com → OAuth client. Redirect:
#   {origin}/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
# Microsoft Entra ID: app-registratie. Redirect:
#   {origin}/api/auth/callback/microsoft-entra-id
AUTH_MICROSOFT_ENTRA_ID_ID=""
AUTH_MICROSOFT_ENTRA_ID_SECRET=""
# Issuer, bv. https://login.microsoftonline.com/<tenant-id>/v2.0 (of /common/v2.0)
AUTH_MICROSOFT_ENTRA_ID_ISSUER=""

# --- Demo-login ---
# Met DEMO_LOGIN="true" verschijnt op de inlogpagina een snel-inlog-paneel met
# alle demo-accounts (superadmin, owners, leden van beide tenants) zodat je
# zonder wachtwoord/magic link elke rol & sportschool kunt proberen.
# Werkt OOK in productie (bewust, voor demo's). LET OP: omzeilt authenticatie
# volledig — alleen aanzetten op een demo-/testomgeving, niet met echte data.
DEMO_LOGIN="false"

# --- Web-push (VAPID) ---
# Genereer een sleutelpaar met: npx web-push generate-vapid-keys
# Zonder deze sleutels degradeert push netjes (in-app + e-mail blijven werken).
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
# Contact-URI voor de push-service (mailto: of https:).
VAPID_SUBJECT="mailto:support@gymrebel.app"

# --- Cron (geplande schema-publicatie) ---
# Geheime sleutel die Vercel Cron als Bearer-token meestuurt naar
# /api/cron/publish-schemas. Zet dit in productie zodat de route niet open is.
CRON_SECRET=""
