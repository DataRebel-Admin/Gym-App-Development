// GymRebel Prisma schema — zie CLAUDE.md voor architectuur-principes.
//
// Multitenant: élk model behalve Tenant heeft een `tenantId` + relatie naar
// Tenant en een @@index([tenantId]). RLS-policies (prompt 04) zorgen voor
// daadwerkelijke isolatie op DB-niveau.
//
// NB: het trainings-sessiemodel heet `WorkoutSession` (niet `Session`) om
// botsing met het Auth.js `Session`-model (prompt 03) te voorkomen.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // DIRECT_URL wordt gebruikt voor migraties wanneer DATABASE_URL een
  // connection pooler is (bv. Neon/Vercel Postgres).
  directUrl = env("DIRECT_URL")
}

enum Role {
  SUPERADMIN // platform-beheerder, transcendeert tenants (tenantId == null)
  TENANT_ADMIN // sportschooleigenaar/beheerder (voorheen OWNER)
  TENANT_MEMBER // sporter (voorheen MEMBER)
}

enum TenantStatus {
  ACTIVE
  INACTIVE
}

enum Locale {
  NL
  EN
  FY
}

enum MachineType {
  CARDIO
  KRACHT
  VRIJE_GEWICHTEN
  OVERIG
}

model Tenant {
  id          String   @id @default(cuid())
  slug        String   @unique // subdomein, bv. "fitpower"
  name        String
  logoUrl     String?
  accentColor String? // primaire kleur (hex), bv. "#E84B1F"
  secondaryColor String? // secundaire kleur (hex)
  faviconUrl  String?
  fontFamily  String? // optioneel; CSS font-family naam
  locale      Locale       @default(NL)
  status      TenantStatus @default(ACTIVE)
  aiEnabled   Boolean      @default(false)
  // --- Zakelijke gegevens (tenant-instellingen, owner) ---
  contactEmail String?
  contactPhone String?
  addressLine  String?
  postalCode   String?
  city         String?
  country      String?
  website      String?
  vatNumber    String? // BTW-nummer
  cocNumber    String? // KvK-nummer
  socials      Json? // { instagram, facebook, ... }
  openingHours Json? // { mon: "06:00-22:00", ... }
  deletedAt   DateTime? // soft-delete; null = actief bestaand
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  invitations       Invitation[]
  users             User[]
  machines          Machine[]
  exercises         Exercise[]
  templates         WorkoutTemplate[]
  workoutDays       WorkoutDay[]
  workoutItems      WorkoutExerciseItem[]
  assignedWorkouts  AssignedWorkout[]
  sessions          WorkoutSession[]
  performanceEntries PerformanceEntry[]
  aiUsages          AiUsage[]
  groupClasses      GroupClass[]
  classSessions     ClassSession[]
  classEnrollments  ClassEnrollment[]
}

// Eén rij per AI-assistent-vraag — voor rate-limiting (per lid/dag) en
// kostenmonitoring (per tenant/maand).
model AiUsage {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([userId, createdAt])
}

// --- Groepslessen / rooster (prompt 12) ---

model GroupClass {
  id              String   @id @default(cuid())
  tenantId        String
  name            String
  description     String?
  instructorName  String?
  maxParticipants Int      @default(12)
  createdAt       DateTime @default(now())

  tenant   Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sessions ClassSession[]

  @@index([tenantId])
}

model ClassSession {
  id       String   @id @default(cuid())
  tenantId String
  classId  String
  startsAt DateTime
  endsAt   DateTime
  location String?

  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  groupClass  GroupClass        @relation(fields: [classId], references: [id], onDelete: Cascade)
  enrollments ClassEnrollment[]

  @@index([tenantId, startsAt])
  @@index([classId])
}

model ClassEnrollment {
  id         String   @id @default(cuid())
  tenantId   String
  sessionId  String
  userId     String
  enrolledAt DateTime @default(now())

  tenant  Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  session ClassSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Eén aanmelding per lid per sessie.
  @@unique([sessionId, userId])
  @@index([tenantId])
  @@index([userId])
}

model User {
  id            String    @id @default(cuid())
  email         String
  emailVerified DateTime? // vereist door de Auth.js adapter
  name          String?
  image         String? // vereist door de Auth.js adapter
  role          Role      @default(TENANT_MEMBER)
  active        Boolean   @default(true) // account geactiveerd/gedeactiveerd
  archivedAt    DateTime? // gearchiveerd lid (uit actieve roster, niet verwijderd)
  // --- Profiel (accountinstellingen) ---
  firstName     String?
  lastName      String?
  jobTitle      String?
  phone         String?
  timezone      String? // IANA, bv. "Europe/Amsterdam"
  locale        Locale? // persoonlijke taal (override op tenant.locale)
  preferences   Json? // persoonlijke voorkeuren (thema, dichtheid, datum/tijd-notatie, …)
  notificationPrefs Json? // per categorie × kanaal (e-mail/in-app/push)
  consents      Json? // privacy-toestemmingen (bv. marketing)
  deletionRequestedAt DateTime? // verzoek tot accountverwijdering
  // E-mailwijziging met verificatie.
  pendingEmail       String?
  emailChangeToken   String?   @unique
  emailChangeExpires DateTime?
  tenantId      String? // NULL voor SUPERADMIN (transcendeert tenants)
  // Persoonlijke owner-dashboard indeling (widget-volgorde + zichtbaarheid).
  // null = standaard-layout. Geen RLS-impact (kolom op bestaand model).
  dashboardLayout Json?
  createdAt     DateTime  @default(now())

  tenant           Tenant?           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignedWorkouts AssignedWorkout[]
  sessions         WorkoutSession[]
  classEnrollments ClassEnrollment[]
  accounts         Account[] // Auth.js (OAuth, later)
  authSessions     Session[] // Auth.js DB-sessies (we gebruiken jwt, maar model vereist)

  // Email is uniek per tenant (niet globaal): twee tenants mogen hetzelfde
  // emailadres hebben. De tenant-scoped adapter scoped lookups hierop.
  // SUPERADMIN (tenantId NULL) is globaal uniek via een partial index (zie migratie).
  @@unique([tenantId, email])
  @@index([tenantId])
}

// Uitnodiging om als gebruiker bij een tenant te komen (e-mail + token).
model Invitation {
  id          String    @id @default(cuid())
  tenantId    String
  email       String
  role        Role      @default(TENANT_MEMBER)
  token       String    @unique
  expiresAt   DateTime
  invitedById String? // User.id van de uitnodiger (superadmin of tenant-admin)
  acceptedAt  DateTime?
  createdAt   DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([token])
}

// Audit log van beheertaken. Bewust GEEN FK naar Tenant/User (forensisch: blijft
// bestaan na verwijdering). tenantId NULL = platform-niveau (bv. tenant aanmaken).
model AuditLog {
  id         String      @id @default(cuid())
  actorId    String?
  actorEmail String?
  actorRole  Role?
  tenantId   String?
  action     String // bv. "tenant.create", "branding.update", "user.role.change"
  category   String? // afgeleid van de action-prefix (user/schema/exercise/tenant/auth)
  status     AuditStatus @default(SUCCESS)
  targetType String?
  targetId   String?
  oldValue   Json? // staat vóór de wijziging (indien relevant)
  newValue   Json? // staat ná de wijziging (indien relevant)
  ipAddress  String? // geanonimiseerd (laatste octet → 0 / IPv6 ingekort)
  userAgent  String? // browser/device
  metadata   Json?
  createdAt  DateTime    @default(now())

  @@index([tenantId, createdAt])
  @@index([action, createdAt])
  @@index([tenantId, category, createdAt])
  @@index([actorId, createdAt])
}

enum AuditStatus {
  SUCCESS
  FAILED
}

// --- Auth.js (NextAuth v5) infra-tabellen ---
// Géén tenantId/RLS: dit zijn framework-tabellen, geen tenant-business-data.
// De Prisma-adapter maakt deze rijen aan zonder tenant-context.

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Machine {
  id             String      @id @default(cuid())
  tenantId       String
  name           String
  type           MachineType @default(OVERIG)
  description    String?
  instructionsMd String?     @db.Text
  videoUrl       String?
  imageUrl       String?
  qrToken        String      @unique
  createdAt      DateTime    @default(now())

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  exercises Exercise[]

  @@index([tenantId])
}

model Exercise {
  id           String  @id @default(cuid())
  tenantId     String
  name         String
  description  String?
  targetMuscle String?
  machineId    String? // nullable: lichaamsgewicht-oefeningen hebben geen machine
  catalogId    String? // optioneel: link naar de globale ExerciseCatalog (bron van media/instructies)

  tenant             Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  machine            Machine?              @relation(fields: [machineId], references: [id], onDelete: SetNull)
  catalog            ExerciseCatalog?      @relation(fields: [catalogId], references: [id], onDelete: SetNull)
  workoutItems       WorkoutExerciseItem[]
  performanceEntries PerformanceEntry[]

  @@index([tenantId])
  @@index([machineId])
  @@index([catalogId])
}

// Globale oefeningen-catalogus (externe dataset, 1.324 records). NIET tenant-scoped
// en GEEN RLS — net als Tenant/Auth-tabellen. Dit is de bron van waarheid voor
// media, spiergroepen en (meertalige) instructies; tenants cureren hun eigen
// selectie via Exercise.catalogId. Gevuld door scripts/import-exercises.mjs.
model ExerciseCatalog {
  id               String   @id
  name             String
  category         String
  bodyPart         String   @map("body_part")
  equipment        String
  target           String
  muscleGroup      String?  @map("muscle_group")
  secondaryMuscles String[] @map("secondary_muscles")
  instructions     Json // { en, es, it, tr, nl } — vrije tekst per taal
  instructionSteps Json?    @map("instruction_steps") // { en: [...], ..., nl: [...] }
  imageUrl         String   @map("image_url")
  gifUrl           String   @map("gif_url")
  createdAt        DateTime @default(now()) @map("created_at")

  exercises Exercise[]

  @@index([category])
  @@index([equipment])
  @@index([target])
  @@map("exercise_catalog")
}

model WorkoutTemplate {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  isLibrary   Boolean  @default(false) // true = zichtbaar als herbruikbare template
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant           Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  days             WorkoutDay[]
  items            WorkoutExerciseItem[]
  assignedWorkouts AssignedWorkout[]

  @@index([tenantId])
}

// Trainingsdag binnen een schema (schema → dagen → oefeningen).
model WorkoutDay {
  id         String @id @default(cuid())
  tenantId   String
  templateId String
  order      Int    @default(0)
  name       String @default("Dag 1")

  tenant   Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  template WorkoutTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  items    WorkoutExerciseItem[]

  @@index([tenantId])
  @@index([templateId])
}

model WorkoutExerciseItem {
  id          String @id @default(cuid())
  tenantId    String
  templateId  String
  exerciseId  String
  dayId       String? // trainingsdag binnen het schema (na backfill altijd gezet)
  order       Int    @default(0)
  sets        Int    @default(3)
  reps        Int    @default(10)
  restSeconds Int    @default(60)
  weightKg    Float? // streefgewicht (optioneel)
  notes       String? // opmerking bij de oefening (optioneel)

  tenant   Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  template WorkoutTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  day      WorkoutDay?     @relation(fields: [dayId], references: [id], onDelete: Cascade)
  exercise Exercise        @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([templateId])
  @@index([dayId])
  @@index([exerciseId])
}

model AssignedWorkout {
  id         String   @id @default(cuid())
  tenantId   String
  userId     String // MEMBER aan wie het schema is toegewezen
  templateId String? // nullable wanneer handmatig gebouwd
  customName String? // naam bij handmatig opgebouwd schema
  createdAt  DateTime @default(now())

  tenant   Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  template WorkoutTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([userId])
}

model WorkoutSession {
  id        String    @id @default(cuid())
  tenantId  String
  userId    String
  startedAt DateTime  @default(now())
  endedAt   DateTime?

  tenant             Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  performanceEntries PerformanceEntry[]

  @@index([tenantId])
  @@index([userId])
}

model PerformanceEntry {
  id         String  @id @default(cuid())
  tenantId   String
  sessionId  String
  exerciseId String
  setNumber  Int
  reps       Int
  weightKg   Float
  notes      String?

  tenant   Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  session  WorkoutSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  exercise Exercise       @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  // Eén entry per set binnen een sessie+oefening (maakt upsert mogelijk).
  @@unique([sessionId, exerciseId, setNumber])
  @@index([tenantId])
  @@index([sessionId])
  @@index([exerciseId])
}
