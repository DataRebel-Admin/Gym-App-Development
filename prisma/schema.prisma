// GymRebel Prisma schema — zie CLAUDE.md voor architectuur-principes.
//
// Multitenant: élk model behalve Tenant heeft een `tenantId` + relatie naar
// Tenant en een @@index([tenantId]). RLS-policies (prompt 04) zorgen voor
// daadwerkelijke isolatie op DB-niveau.
//
// NB: het trainings-sessiemodel heet `WorkoutSession` (niet `Session`) om
// botsing met het Auth.js `Session`-model (prompt 03) te voorkomen.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // DIRECT_URL wordt gebruikt voor migraties wanneer DATABASE_URL een
  // connection pooler is (bv. Neon/Vercel Postgres).
  directUrl = env("DIRECT_URL")
}

enum Role {
  SUPERADMIN // platform-beheerder, transcendeert tenants (tenantId == null)
  TENANT_ADMIN // sportschooleigenaar/beheerder (voorheen OWNER)
  TENANT_STAFF // sportschoolmedewerker/coach (permissie-gestuurd, tenant-gebonden)
  TENANT_MEMBER // sporter (voorheen MEMBER)
}

enum TenantStatus {
  ACTIVE
  INACTIVE
}

enum Locale {
  NL
  EN
  FY
}

enum MachineType {
  CARDIO
  KRACHT
  VRIJE_GEWICHTEN
  OVERIG
}

// Onderhoudsstatus van een machine. ACTIVE/MAINTENANCE_DUE worden automatisch
// getransitioneerd (gebruik-/tijddrempel); IN_MAINTENANCE/OUT_OF_SERVICE zet een
// beheerder handmatig (die worden nooit door de auto-evaluatie overschreven).
enum MachineStatus {
  ACTIVE
  MAINTENANCE_DUE
  IN_MAINTENANCE
  OUT_OF_SERVICE
}

// Soort onderhoudsactie — extensiepunt zodat later inspecties, keuringen en
// veiligheidschecks er zonder herbouw bij kunnen (default SERVICE).
enum MaintenanceKind {
  SERVICE
  INSPECTION
  SAFETY_CHECK
  REPAIR
}

// Moeilijkheidsgraad voor eigen (tenant-)oefeningen. Catalogus-oefeningen leiden
// hun niveau heuristisch af (zie lib/exercise.ts deriveDifficulty).
enum ExerciseDifficulty {
  BEGINNER
  GEMIDDELD
  GEVORDERD
}

enum Gender {
  MAN
  VROUW
  NON_BINAIR
  ONBEKEND
}

// Levenscyclus van een aan een lid toegewezen schema. Een lid kan meerdere
// toewijzingen hebben (bv. een actief schema + een gepland toekomstig schema);
// het lid ziet er telkens precies één — zie lib/member.ts (getAssignedSchema).
enum AssignmentStatus {
  DRAFT // concept — nog niet zichtbaar voor het lid
  SCHEDULED // gepland — wordt zichtbaar zodra availableFrom is bereikt
  PUBLISHED // live — zichtbaar voor het lid
  ARCHIVED // niet meer actief (handmatig of na einddatum)
}

// Soort herbruikbare template in de bibliotheek. SCHEMA = volledig trainingsschema
// (meerdere dagen); DAY = één herbruikbare trainingsdag (Push/Pull/Legs/…) die je
// als blok in een schema kunt invoegen ("Dag toevoegen vanuit template").
enum WorkoutTemplateKind {
  SCHEMA
  DAY
}

// Mate van controle die een sportschool houdt over zelf-gebouwde lid-schema's.
// DISABLED = functie uit; APPROVAL = lid dient in, coach keurt goed; DIRECT = lid
// activeert zelf (sportschool ziet mee, geen goedkeuring). Per tenant instelbaar.
enum MemberSchemaMode {
  DISABLED
  APPROVAL
  DIRECT
}

// Herkomst van een toegewezen schema: COACH (owner/medewerker stelde samen) of
// MEMBER (lid bouwde het zelf). Bepaalt of de lid-levenscyclus (`memberStatus`)
// van toepassing is.
enum AssignmentOrigin {
  COACH
  MEMBER
}

// Levenscyclus van een zelf-gebouwd lid-schema (los van de zichtbaarheids-`status`
// op AssignedWorkout). DRAFT = concept; IN_REVIEW = ingediend ter controle;
// APPROVED = goedgekeurd (klaar om te activeren); REJECTED = afgewezen (met reden);
// ACTIVE = in gebruik; PAUSED = tijdelijk gepauzeerd.
enum MemberSchemaStatus {
  DRAFT
  IN_REVIEW
  APPROVED
  REJECTED
  ACTIVE
  PAUSED
}

// Doel van een schema-aanvraag door een sporter.
enum SchemaRequestGoal {
  MUSCLE // spiermassa opbouwen
  WEIGHT_LOSS // afvallen
  CONDITION // conditie verbeteren
  REHAB // revalidatie
  STRENGTH // krachttraining
  OTHER // anders (zie beschrijving)
}

// Levenscyclus van een schema-aanvraag (sporter → coach → oplevering).
enum SchemaRequestStatus {
  NEW // ingediend, nog niet opgepakt
  IN_PROGRESS // coach is ermee bezig
  SCHEMA_CREATED // schema gemaakt, nog niet afgerond
  COMPLETED // afgerond (schema staat klaar voor het lid)
  REJECTED // afgewezen door de coach
  CANCELLED // geannuleerd door het lid
}

model Tenant {
  id          String   @id @default(cuid())
  slug        String   @unique // subdomein, bv. "gymrebel"
  name        String
  logoUrl     String?
  accentColor String? // primaire kleur (hex), bv. "#E84B1F"
  secondaryColor String? // secundaire kleur (hex)
  faviconUrl  String?
  fontFamily  String? // optioneel; CSS font-family naam
  locale      Locale       @default(NL)
  status      TenantStatus @default(ACTIVE)
  aiEnabled   Boolean      @default(false)
  // Trofeeën/achievements-systeem aan voor deze sportschool (opt-in per gym).
  achievementsEnabled Boolean @default(false)
  // Mate van controle over zelf-gebouwde lid-schema's (opt-in per sportschool).
  memberSchemaMode MemberSchemaMode @default(DISABLED)
  // Motiverende Workout Quotes na een afgeronde training (aan/uit per sportschool).
  quotesEnabled Boolean    @default(true)
  // Lesrooster/aanmelden voor lessen aan of uit voor deze sportschool. Default aan;
  // uitzetten verbergt alle les-UI (nav/pagina's) en blokkeert in-/uitschrijven.
  classesEnabled Boolean   @default(true)
  // Door de owner geselecteerde meetvelden (array van metric-keys uit
  // lib/measurement-meta.ts). NULL = alle velden actief (backward-compat).
  enabledMeasurementFields Json?
  // Door de owner toegevoegde eigen quotes (array van strings). NULL = alleen de
  // standaard-quotes uit lib/workout-quotes.ts.
  customQuotes Json?
  // --- Zakelijke gegevens (tenant-instellingen, owner) ---
  contactEmail String?
  contactPhone String?
  addressLine  String?
  postalCode   String?
  city         String?
  country      String?
  website      String?
  vatNumber    String? // BTW-nummer
  cocNumber    String? // KvK-nummer
  socials      Json? // { instagram, facebook, ... }
  openingHours Json? // { mon: "06:00-22:00", ... }
  deletedAt   DateTime? // soft-delete; null = actief bestaand
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  invitations       Invitation[]
  users             User[]
  machines          Machine[]
  exercises         Exercise[]
  templates         WorkoutTemplate[]
  workoutDays       WorkoutDay[]
  workoutItems      WorkoutExerciseItem[]
  assignedWorkouts  AssignedWorkout[]
  sessions          WorkoutSession[]
  performanceEntries PerformanceEntry[]
  aiUsages          AiUsage[]
  groupClasses      GroupClass[]
  classSessions     ClassSession[]
  classEnrollments  ClassEnrollment[]
  notifications     Notification[]
  pushSubscriptions PushSubscription[]
  nativePushTokens  NativePushToken[]
  measurements      Measurement[]
  measurementPhotos MeasurementPhoto[]
  memberGoals       MemberGoal[]
  schemaRequests    SchemaRequest[]
  coachNotes        CoachNote[]
  coachAssignments  CoachAssignment[]
  schemaFrameworks  SchemaFramework[]
  memberFrameworkAssignments MemberFrameworkAssignment[]
  earnedAchievements EarnedAchievement[]
  maintenanceRecords MaintenanceRecord[]
  maintenancePolicies MaintenancePolicy[]
  featureFlags        FeatureFlag[]
  machineScans        MachineScan[]
}

/**
 * Tenant-specifieke feature flag (module aan/uit per sportschool). Alléén de
 * Superadmin muteert deze. Eén rij per (tenant, key); ontbreekt een rij, dan
 * geldt de code-default uit `lib/features/catalog.ts`. De sleutels zijn géén
 * enum (uitbreidbaar zonder migratie) — de code-registry is de bron van waarheid.
 * Tenant-scoped + RLS (zoals de andere tenant-modellen).
 */
model FeatureFlag {
  id             String   @id @default(cuid())
  tenantId       String
  key            String // FeatureKey uit lib/features/catalog.ts
  enabled        Boolean
  updatedById    String? // Superadmin die 't wijzigde (geen FK — overleeft delete)
  updatedByEmail String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
  @@index([tenantId])
}

// In-app melding voor één gebruiker. `tenantId` is nullable zodat ook een
// SUPERADMIN (zonder tenant) een melding kan krijgen. Beveiliging loopt via de
// verplichte `userId`-filter in alle queries (zoals de andere user-scoped data).
model Notification {
  id        String    @id @default(cuid())
  tenantId  String?
  userId    String
  category  String // bv. "schemas", "security" — matcht een meldingscategorie
  title     String
  body      String?
  link      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([userId, createdAt])
  @@index([tenantId])
}

// --- Body Composition & Progress Tracking ---

// Herkomst van een meting. MANUAL = handmatig; de rest is integratie-prep
// (device-sync), nog niet actief — zie Measurement.externalId/raw.
enum MeasurementSource {
  MANUAL
  INBODY
  TANITA
  EVOLT
  GARMIN
  APPLE_HEALTH
  GOOGLE_FIT
}

enum PhotoPose {
  FRONT
  SIDE
  BACK
}

enum GoalMetric {
  WEIGHT
  BODY_FAT
  MUSCLE_MASS
  BMI
  WAIST
}

// Eén lichaamsmeting op een moment. Historisch — nooit overschrijven. Velden
// nullable zodat een trainer alleen invult wat de weegschaal levert. `extra`
// (Json) houdt de structuur uitbreidbaar voor toekomstige meetwaarden.
model Measurement {
  id           String            @id @default(cuid())
  tenantId     String
  userId       String // het lid
  recordedById String? // trainer/owner die de meting invoerde
  measuredAt   DateTime
  notes        String?
  source       MeasurementSource @default(MANUAL)
  externalId   String? // integratie-prep: device-record-id
  raw          Json? // integratie-prep: ruwe device-payload
  // Lichaamssamenstelling
  weightKg     Float?
  bodyFatPct   Float?
  muscleMassKg Float?
  fatMassKg    Float?
  bmi          Float?
  waterPct     Float?
  boneMassKg   Float?
  visceralFat  Float?
  bmr          Int?
  metabolicAge Int?
  // Omtrek (cm)
  chestCm      Float?
  waistCm      Float?
  hipsCm       Float?
  neckCm       Float?
  armLeftCm    Float?
  armRightCm   Float?
  thighLeftCm  Float?
  thighRightCm Float?
  calfLeftCm   Float?
  calfRightCm  Float?
  // Conditie (fitness) — voortgang is méér dan lichaamssamenstelling alleen.
  restingHrBpm Int? // rusthartslag (bpm)
  extra        Json? // extra/toekomstige meetwaarden
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  tenant Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User               @relation("MemberMeasurements", fields: [userId], references: [id], onDelete: Cascade)
  photos MeasurementPhoto[]

  @@index([tenantId])
  @@index([userId, measuredAt])
}

model MeasurementPhoto {
  id            String    @id @default(cuid())
  tenantId      String
  measurementId String
  pose          PhotoPose
  url           String
  createdAt     DateTime  @default(now())

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  measurement Measurement @relation(fields: [measurementId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([measurementId])
}

// Persoonlijk doel per metric, ingesteld door de trainer. Historisch (meerdere
// mogen bestaan); de app toont het meest recente actieve doel per metric.
model MemberGoal {
  id          String     @id @default(cuid())
  tenantId    String
  userId      String
  metric      GoalMetric
  startValue  Float?
  targetValue Float
  targetDate  DateTime?
  createdById String?
  achievedAt  DateTime?
  createdAt   DateTime   @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation("MemberGoals", fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId, metric])
}

// Eén behaalde trofee/achievement/mijlpaal door een lid. De definities zijn
// code-gestuurd (lib/achievements/definitions.ts) — hier bewaren we alleen wélke
// (`key`) en wanneer (`earnedAt`) behaald is. Tenant-scoped business-data (RLS,
// zie prisma/sql/rls.sql). `@@unique([tenantId, userId, key])` garandeert dat een
// achievement precies één keer wordt toegekend (geen dubbele toekenning).
//
// `category`/`rarity` zijn gedenormaliseerd zodat overzichten (mooiste trofee,
// filters) niet elke keer de registry hoeven te joinen. `value` bewaart de
// metricwaarde op het moment van behalen; `celebratedAt` markeert of de
// celebration-overlay/melding al getoond is (null = nog vieren).
model EarnedAchievement {
  id           String    @id @default(cuid())
  tenantId     String
  userId       String
  key          String // definitie-key uit lib/achievements/definitions.ts
  category     String
  rarity       String
  value        Float? // metricwaarde op moment van behalen (bv. 100 trainingen)
  earnedAt     DateTime  @default(now())
  celebratedAt DateTime? // celebration getoond? null = nog vieren
  createdAt    DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId, key])
  @@index([tenantId, userId])
  @@index([tenantId, category])
  @@index([tenantId, earnedAt])
  @@index([userId, celebratedAt])
}

// Eén rij per AI-assistent-vraag — voor rate-limiting (per lid/dag) en
// kostenmonitoring (per tenant/maand).
model AiUsage {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([userId, createdAt])
}

// --- Groepslessen / rooster (prompt 12) ---

model GroupClass {
  id              String   @id @default(cuid())
  tenantId        String
  name            String
  description     String?
  instructorName  String?
  maxParticipants Int      @default(12)
  createdAt       DateTime @default(now())

  tenant   Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sessions ClassSession[]

  @@index([tenantId])
}

model ClassSession {
  id       String   @id @default(cuid())
  tenantId String
  classId  String
  startsAt DateTime
  endsAt   DateTime
  location String?

  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  groupClass  GroupClass        @relation(fields: [classId], references: [id], onDelete: Cascade)
  enrollments ClassEnrollment[]

  @@index([tenantId, startsAt])
  @@index([classId])
}

model ClassEnrollment {
  id         String   @id @default(cuid())
  tenantId   String
  sessionId  String
  userId     String
  enrolledAt DateTime @default(now())

  tenant  Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  session ClassSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Eén aanmelding per lid per sessie.
  @@unique([sessionId, userId])
  @@index([tenantId])
  @@index([userId])
}

model User {
  id            String    @id @default(cuid())
  email         String
  emailVerified DateTime? // vereist door de Auth.js adapter
  name          String?
  image         String? // vereist door de Auth.js adapter
  role          Role      @default(TENANT_MEMBER)
  active        Boolean   @default(true) // account geactiveerd/gedeactiveerd
  archivedAt    DateTime? // gearchiveerd lid (uit actieve roster, niet verwijderd)
  // --- Profiel (accountinstellingen) ---
  firstName     String?
  lastName      String?
  jobTitle      String?
  phone         String?
  birthDate     DateTime? // geboortedatum (o.a. via bulk-import)
  gender        Gender? // geslacht (o.a. via bulk-import)
  memberNumber  String? // sportschool-lidnummer (uniek per tenant; o.a. via bulk-import)
  timezone      String? // IANA, bv. "Europe/Amsterdam"
  locale        Locale? // persoonlijke taal (override op tenant.locale)
  preferences   Json? // persoonlijke voorkeuren (thema, dichtheid, datum/tijd-notatie, …)
  notificationPrefs Json? // per categorie × kanaal (e-mail/in-app/push)
  // Per-medewerker permissie-override (TENANT_STAFF). null = role-default.
  // Vorm: Record<Permission, boolean> — zie lib/rbac.ts.
  permissions   Json?
  consents      Json? // privacy-toestemmingen (bv. marketing)
  // Door de sporter zélf gekozen trainingsdoelen (personalisatie). Vorm:
  // string[] met keys uit lib/training-goals.ts. null/[] = nog niet gekozen.
  trainingGoals Json?
  deletionRequestedAt DateTime? // verzoek tot accountverwijdering
  // --- Beveiliging ---
  passwordHash     String? // bcrypt; null = alleen magic-link
  twoFactorSecret  String? // base32 TOTP-secret (pending of actief)
  twoFactorEnabled Boolean   @default(false)
  sessionsValidFrom DateTime? // sessies vóór dit moment zijn ongeldig (logout overal)
  // E-mailwijziging met verificatie.
  pendingEmail       String?
  emailChangeToken   String?   @unique
  emailChangeExpires DateTime?
  // Wachtwoord-reset via e-mail (eenmalige, kortlevende token — 1 uur).
  passwordResetToken   String?   @unique
  passwordResetExpires DateTime?
  tenantId      String? // NULL voor SUPERADMIN (transcendeert tenants)
  // Persoonlijke owner-dashboard indeling (widget-volgorde + zichtbaarheid).
  // null = standaard-layout. Geen RLS-impact (kolom op bestaand model).
  dashboardLayout Json?
  createdAt     DateTime  @default(now())

  tenant           Tenant?           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignedWorkouts AssignedWorkout[]
  sessions         WorkoutSession[]
  classEnrollments ClassEnrollment[]
  accounts         Account[] // Auth.js (OAuth, later)
  authSessions     Session[] // Auth.js DB-sessies (we gebruiken jwt, maar model vereist)
  authenticators   Authenticator[] // WebAuthn/passkeys (biometrische login)
  userSessions     UserSession[] // device/sessie-registratie
  notifications    Notification[]
  pushSubscriptions PushSubscription[]
  nativePushTokens NativePushToken[] // APNs/FCM device-tokens (native app)
  measurements     Measurement[] @relation("MemberMeasurements")
  goals            MemberGoal[]  @relation("MemberGoals")
  schemaRequests   SchemaRequest[]
  coachNotes         CoachNote[] @relation("CoachNoteMember") // notities óver dit lid
  authoredCoachNotes CoachNote[] @relation("CoachNoteAuthor") // notities geschreven door deze medewerker
  coachingMembers    CoachAssignment[] @relation("CoachAssignmentCoach") // leden die deze coach begeleidt
  assignedCoaches    CoachAssignment[] @relation("CoachAssignmentMember") // coaches van dit lid
  earnedAchievements EarnedAchievement[]
  maintenanceRecords MaintenanceRecord[] @relation("MaintenancePerformer") // onderhoud uitgevoerd door deze gebruiker
  machineScans       MachineScan[] // door dit lid gescande apparaat-QR's

  // Email is uniek per tenant (niet globaal): twee tenants mogen hetzelfde
  // emailadres hebben. De tenant-scoped adapter scoped lookups hierop.
  // SUPERADMIN (tenantId NULL) is globaal uniek via een partial index (zie migratie).
  @@unique([tenantId, email])
  // Lidnummer uniek per tenant (NULLs mogen meermaals voorkomen in Postgres).
  @@unique([tenantId, memberNumber])
  @@index([tenantId])
}

// Uitnodiging om als gebruiker bij een tenant te komen (e-mail + token).
model Invitation {
  id          String    @id @default(cuid())
  tenantId    String
  email       String
  role        Role      @default(TENANT_MEMBER)
  token       String    @unique
  expiresAt   DateTime
  invitedById String? // User.id van de uitnodiger (superadmin of tenant-admin)
  acceptedAt  DateTime?
  createdAt   DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([token])
}

// Audit log van beheertaken. Bewust GEEN FK naar Tenant/User (forensisch: blijft
// bestaan na verwijdering). tenantId NULL = platform-niveau (bv. tenant aanmaken).
model AuditLog {
  id         String      @id @default(cuid())
  actorId    String?
  actorEmail String?
  actorRole  Role?
  tenantId   String?
  action     String // bv. "tenant.create", "branding.update", "user.role.change"
  category   String? // afgeleid van de action-prefix (user/schema/exercise/tenant/auth)
  status     AuditStatus @default(SUCCESS)
  targetType String?
  targetId   String?
  oldValue   Json? // staat vóór de wijziging (indien relevant)
  newValue   Json? // staat ná de wijziging (indien relevant)
  ipAddress  String? // geanonimiseerd (laatste octet → 0 / IPv6 ingekort)
  userAgent  String? // browser/device
  metadata   Json?
  createdAt  DateTime    @default(now())

  @@index([tenantId, createdAt])
  @@index([action, createdAt])
  @@index([tenantId, category, createdAt])
  @@index([actorId, createdAt])
}

enum AuditStatus {
  SUCCESS
  FAILED
}

// --- E-mailtemplatebeheer (Superadmin) ---
// Globale platform-tabel (géén tenantId/RLS, zoals AuditLog/ExerciseCatalog): de
// content is bron voor álle tenants; de gebrande shell + branding worden per
// tenant runtime toegevoegd (zie lib/email/template-render.ts). Editbaar concept
// + gepubliceerde snapshot; de app verstuurt de gepubliceerde versie en valt
// terug op de hardgecodeerde composers in lib/email/messages.ts.

enum EmailTemplateStatus {
  DRAFT // er staan onuitgegeven concept-wijzigingen klaar
  PUBLISHED // concept == gepubliceerde inhoud (live)
}

model EmailTemplate {
  id      String @id @default(cuid())
  key     String // bv. "magicLink", "invite", "welcome" — zie lib/email/template-defaults.ts
  locale  Locale @default(NL)

  // Werk-concept (autosave):
  subject   String
  preheader String?
  bodyHtml  String  @db.Text

  // Gepubliceerde snapshot — dít verstuurt de app:
  publishedSubject   String?
  publishedPreheader String?
  publishedBodyHtml  String?   @db.Text
  publishedAt        DateTime?

  status         EmailTemplateStatus @default(DRAFT)
  updatedById    String?
  updatedByEmail String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  versions EmailTemplateVersion[]

  @@unique([key, locale])
}

model EmailTemplateVersion {
  id          String        @id @default(cuid())
  templateId  String
  template    EmailTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  subject     String
  preheader   String?
  bodyHtml    String        @db.Text
  note        String? // opmerking van de auteur bij publicatie
  authorId    String?
  authorEmail String?
  createdAt   DateTime      @default(now())

  @@index([templateId, createdAt])
}

// --- Auth.js (NextAuth v5) infra-tabellen ---
// Géén tenantId/RLS: dit zijn framework-tabellen, geen tenant-business-data.
// De Prisma-adapter maakt deze rijen aan zonder tenant-context.

// Device-/sessie-registratie voor "actieve sessies" + op afstand uitloggen.
model UserSession {
  id         String    @id @default(cuid())
  userId     String
  userAgent  String?
  ip         String?
  createdAt  DateTime  @default(now())
  lastSeenAt DateTime  @default(now())
  revokedAt  DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// WebAuthn/passkey-credential. Auth-infra (zoals Account/Session): géén tenantId/
// RLS — de login zoekt de credential vóór er tenant-context is. De tenant volgt
// uit de gekoppelde User. credentialId/publicKey worden base64url opgeslagen.
model Authenticator {
  id           String    @id @default(cuid())
  userId       String
  credentialId String    @unique
  publicKey    String // base64url (COSE public key)
  counter      Int       @default(0)
  transports   String[] // bv. ["internal","hybrid"]
  deviceType   String? // "singleDevice" | "multiDevice"
  backedUp     Boolean   @default(false)
  name         String? // gebruiker-gekozen label ("iPhone van Duco")
  createdAt    DateTime  @default(now())
  lastUsedAt   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Machine {
  id             String      @id @default(cuid())
  tenantId       String
  name           String
  type           MachineType @default(OVERIG)
  description    String?
  instructionsMd String?     @db.Text
  videoUrl       String?
  imageUrl       String?
  qrToken        String      @unique
  createdAt      DateTime    @default(now())

  // --- QR-scan-tracking (gedenormaliseerd voor goedkoop tonen) ---
  scanCount     Int       @default(0) // totaal aantal scans van de publieke QR
  lastScannedAt DateTime? // laatste scanmoment

  // --- Inventaris (onderhoudsbeheer) ---
  location     String? // locatie binnen de sportschool (bv. "Zone A", "1e verdieping")
  serialNumber String? // serie- of intern inventarisnummer
  purchaseDate DateTime? // aankoopdatum

  // --- Onderhoudsstatus & -regels ---
  status                  MachineStatus @default(ACTIVE)
  usageCount              Int           @default(0) // gebruiksmomenten sinds laatste onderhoud
  usageThreshold          Int? // gebruikslimiet (NULL = geen gebruik-trigger)
  maintenanceIntervalDays Int? // tijdslimiet in dagen (NULL = geen tijd-trigger)
  lastMaintenanceAt       DateTime? // laatst uitgevoerd onderhoud
  nextMaintenanceAt       DateTime? // afgeleid & opgeslagen (lastMaintenance + interval)
  // Idempotente melding-markers: voorkomen dubbele "bijna nodig"/"nu nodig"-meldingen.
  maintenanceDueNotifiedAt  DateTime?
  maintenanceWarnNotifiedAt DateTime?

  tenant             Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  exercises          Exercise[]
  maintenanceRecords MaintenanceRecord[]
  scans              MachineScan[]

  @@index([tenantId])
  @@index([tenantId, status])
}

// Eén rij per QR-scan (publieke /m/[qrToken]-view). Tenant-scoped + RLS. Voedt de
// trends (scans deze week, populairste apparaten) naast de teller op Machine.
model MachineScan {
  id        String   @id @default(cuid())
  tenantId  String
  machineId String
  scannedAt DateTime @default(now())
  userId    String? // ingelogd lid indien bekend; NULL = anonieme scan

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  machine Machine @relation(fields: [machineId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([machineId, scannedAt])
  @@index([tenantId, scannedAt])
}

// Volledige onderhoudshistorie: één rij per uitgevoerd onderhoudsmoment.
// Tenant-scoped + RLS. `kind` maakt het uitbreidbaar naar inspecties/keuringen.
model MaintenanceRecord {
  id              String          @id @default(cuid())
  tenantId        String
  machineId       String
  kind            MaintenanceKind @default(SERVICE)
  performedAt     DateTime        @default(now())
  action          String // uitgevoerde actie (bv. "Kabels vervangen")
  note            String?
  performedById   String? // interne uitvoerder (User) — nullable
  performedByName String? // vrije tekst voor een externe monteur/leverancier
  cost            Decimal?        @db.Decimal(10, 2) // kosten (optioneel)
  usageAtService  Int             @default(0) // teller op het moment van onderhoud (historie)
  nextMaintenanceAt DateTime? // volgende geplande datum die toen is gezet
  createdAt       DateTime        @default(now())

  tenant      Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  machine     Machine @relation(fields: [machineId], references: [id], onDelete: Cascade)
  performedBy User?   @relation("MaintenancePerformer", fields: [performedById], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([machineId])
  @@index([tenantId, performedAt])
}

// Standaard onderhoudsregels per machinetype (tenant-scoped + RLS). Voedt de
// per-machine-regels bij create en "toepassen op alle van dit type".
model MaintenancePolicy {
  id             String      @id @default(cuid())
  tenantId       String
  machineType    MachineType
  usageThreshold Int?
  intervalDays   Int?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, machineType])
  @@index([tenantId])
}

model Exercise {
  id           String  @id @default(cuid())
  tenantId     String
  name         String
  description  String?
  targetMuscle String?
  machineId    String? // nullable: lichaamsgewicht-oefeningen hebben geen machine
  catalogId    String? // optioneel: link naar de globale ExerciseCatalog (bron van media/instructies)

  // Oefeningstype (code-registry, zie lib/exercise-types.ts) — bepaalt wélke
  // parameters relevant zijn (sets/reps/gewicht vs. tijd/afstand/intensiteit…).
  // Bewust een String (geen enum): een nieuw type vereist geen DB-migratie.
  exerciseType String @default("strength")

  // --- Eigen-oefening content (alleen gevuld bij catalogId == null) ---
  // Een "eigen oefening" is een tenant-Exercise zonder catalogus-koppeling; deze
  // velden vervangen dan de catalogus als bron van media/instructies/metadata.
  // Bij catalogus-gekoppelde oefeningen blijven ze NULL (catalogus is leidend).
  muscleGroups     String[]            @default([]) // extra spiergroepen (naast targetMuscle)
  category         String? // categorie (bv. "Kracht", "Cardio")
  difficulty       ExerciseDifficulty? // moeilijkheidsgraad (expliciet voor eigen oefeningen)
  equipment        String? // benodigd materiaal
  tags             String[]            @default([]) // vrije labels
  executionMd      String?  @db.Text // Uitvoering (Markdown)
  coachingTipsMd   String?  @db.Text // Coachingtips (Markdown)
  commonMistakesMd String?  @db.Text // Veelgemaakte fouten (Markdown)
  notesMd          String?  @db.Text // Opmerkingen (Markdown)
  imageUrls        String[]            @default([]) // één of meerdere afbeeldingen
  videoUrl         String? // optionele videolink (YouTube/Vimeo)
  archivedAt       DateTime? // soft-archive: verbergt uit pickers, schema's blijven werken

  tenant             Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  machine            Machine?              @relation(fields: [machineId], references: [id], onDelete: SetNull)
  catalog            ExerciseCatalog?      @relation(fields: [catalogId], references: [id], onDelete: SetNull)
  workoutItems       WorkoutExerciseItem[]
  performanceEntries PerformanceEntry[]

  @@index([tenantId])
  @@index([machineId])
  @@index([catalogId])
}

// Globale oefeningen-catalogus (externe dataset, 1.324 records). NIET tenant-scoped
// en GEEN RLS — net als Tenant/Auth-tabellen. Dit is de bron van waarheid voor
// media, spiergroepen en (meertalige) instructies; tenants cureren hun eigen
// selectie via Exercise.catalogId. Gevuld door scripts/import-exercises.mjs.
model ExerciseCatalog {
  id               String   @id
  name             String
  category         String
  bodyPart         String   @map("body_part")
  equipment        String
  target           String
  muscleGroup      String?  @map("muscle_group")
  secondaryMuscles String[] @map("secondary_muscles")
  instructions     Json // { en, es, it, tr, nl } — vrije tekst per taal
  instructionSteps Json?    @map("instruction_steps") // { en: [...], ..., nl: [...] }
  imageUrl         String   @map("image_url")
  gifUrl           String   @map("gif_url")
  createdAt        DateTime @default(now()) @map("created_at")

  exercises Exercise[]

  @@index([category])
  @@index([equipment])
  @@index([target])
  @@map("exercise_catalog")
}

// Aanvraag van een sporter voor een (nieuw/aangepast) trainingsschema. Tenant-
// scoped business-data (RLS, zie prisma/sql/rls.sql). Vormt samen met de
// schema-toewijzing een complete workflow van aanvraag tot oplevering.
model SchemaRequest {
  id                   String              @id @default(cuid())
  tenantId             String
  userId               String // sporter die de aanvraag indient
  goal                 SchemaRequestGoal
  description          String?             @db.Text // vrije toelichting op het doel
  preferredStart       DateTime? // gewenste startdatum (optioneel)
  notes                String?             @db.Text // extra opmerkingen
  status               SchemaRequestStatus @default(NEW)
  handledById          String? // User.id van de owner/admin die de aanvraag oppakte
  resolvedAssignmentId String? // gekoppelde AssignedWorkout bij oplevering (optioneel)
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@index([userId])
}

// Coachnotitie over een lid, geschreven door een medewerker/eigenaar. Tenant-
// scoped business-data (RLS, zie prisma/sql/rls.sql).
model CoachNote {
  id        String   @id @default(cuid())
  tenantId  String
  memberId  String // lid waarover de notitie gaat
  authorId  String // medewerker/eigenaar die de notitie schreef
  body      String   @db.Text
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  member User   @relation("CoachNoteMember", fields: [memberId], references: [id], onDelete: Cascade)
  author User   @relation("CoachNoteAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([tenantId, memberId])
  @@index([authorId])
}

// Koppeling tussen een coach (medewerker/eigenaar) en een lid dat hij/zij begeleidt.
// Many-to-many: een lid kan meerdere coaches hebben en omgekeerd. Tenant-scoped
// business-data (RLS, zie prisma/sql/rls.sql).
model CoachAssignment {
  id           String   @id @default(cuid())
  tenantId     String
  coachId      String // medewerker/eigenaar die begeleidt
  memberId     String // het lid
  assignedById String? // wie de koppeling maakte
  createdAt    DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  coach  User   @relation("CoachAssignmentCoach", fields: [coachId], references: [id], onDelete: Cascade)
  member User   @relation("CoachAssignmentMember", fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([tenantId, coachId, memberId])
  @@index([tenantId, coachId])
  @@index([tenantId, memberId])
}

// Kader waarbinnen een lid zelf een schema mag samenstellen: toegestane
// oefeningen/types, min/max dagen en sets/reps/rust-grenzen. Tenant-scoped
// business-data (RLS, zie prisma/sql/rls.sql). Eén kader mag `isDefault` zijn
// (tenant-brede standaard); anders per lid gekoppeld via MemberFrameworkAssignment.
model SchemaFramework {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  isDefault   Boolean  @default(false) // tenant-brede standaard (max één zinvol)
  // Beperkingen — leeg/null = geen beperking op dat aspect.
  allowedExerciseIds String[] @default([]) // leeg = alle tenant-oefeningen toegestaan
  allowedTypes       String[] @default([]) // leeg = alle oefeningstypes toegestaan
  minDays            Int?
  maxDays            Int?
  minExercisesPerDay Int?
  maxExercisesPerDay Int?
  setsMin            Int?
  setsMax            Int?
  repsMin            Int?
  repsMax            Int?
  restMin            Int?
  restMax            Int?
  // Override op de tenant-modus: true = altijd goedkeuring, false = direct,
  // null = volg Tenant.memberSchemaMode.
  requireApproval    Boolean?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignments MemberFrameworkAssignment[]

  @@index([tenantId])
}

// Koppelt een kader aan een specifiek lid (max één per lid). Tenant-scoped
// business-data (RLS). Geen koppeling → tenant-default kader → geen kader (vrij).
model MemberFrameworkAssignment {
  id           String   @id @default(cuid())
  tenantId     String
  frameworkId  String
  memberId     String
  assignedById String? // wie de koppeling maakte
  createdAt    DateTime @default(now())

  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  framework SchemaFramework @relation(fields: [frameworkId], references: [id], onDelete: Cascade)

  @@unique([tenantId, memberId])
  @@index([tenantId, frameworkId])
}

model WorkoutTemplate {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  isLibrary   Boolean  @default(false) // true = zichtbaar als herbruikbare template
  // Zichtbaar voor leden als startsjabloon bij zelf-samenstellen (owner-opt-in).
  // Alleen zinvol op library-templates (kind=SCHEMA).
  memberVisible Boolean @default(false)
  kind        WorkoutTemplateKind @default(SCHEMA) // SCHEMA = volledig schema; DAY = herbruikbare dag
  coachNote   String?  @db.Text // coach-notitie op schema-niveau (zichtbaar voor het lid)
  // Geldigheid in weken: hoe lang een schema bruikbaar blijft na publicatie.
  // NULL = onbeperkt. Wordt meegekloond naar het lid-schema → per-lid verloop
  // (flag "Verlopen"/"Nieuw schema nodig", zie lib/schema-status.ts).
  validityWeeks Int?
  // Neutraal trainingsdoel van de template (key uit lib/training-goals.ts).
  // NULL = geen doel getagd. Wordt gebruikt om templates te matchen met de
  // door de sporter gekozen doelen (personalisatie) en als filter/badge.
  goal        String?
  // Vrij toewijsbare badges (keys uit lib/schema-badges.ts) — visuele labels
  // zoals ⭐ Beginner, 🔥 Spieropbouw, ⚡ Intensief. Meegekloond naar lid-schema's.
  badges      String[]  @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant           Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  days             WorkoutDay[]
  items            WorkoutExerciseItem[]
  assignedWorkouts AssignedWorkout[]

  @@index([tenantId])
}

// Trainingsdag binnen een schema (schema → dagen → oefeningen).
model WorkoutDay {
  id         String @id @default(cuid())
  tenantId   String
  templateId String
  order      Int    @default(0)
  name       String @default("Dag 1")
  notes      String? // coach-notitie op dag-niveau (zichtbaar voor het lid)

  tenant   Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  template WorkoutTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  items    WorkoutExerciseItem[]

  @@index([tenantId])
  @@index([templateId])
}

model WorkoutExerciseItem {
  id          String @id @default(cuid())
  tenantId    String
  templateId  String
  exerciseId  String
  dayId       String? // trainingsdag binnen het schema (na backfill altijd gezet)
  order       Int    @default(0)
  sets        Int    @default(3)
  reps        Int    @default(10)
  restSeconds Int    @default(60)
  weightKg    Float? // streefgewicht (optioneel)
  tempo       String? // tempo-cadans, bv. "3-1-1" (optioneel)
  notes       String? // opmerking bij de oefening (optioneel)
  // Type-specifieke doel-parameters (tijd/afstand/intensiteit/…). Velden die op
  // een kolom mappen (sets/reps/restSeconds/weightKg/tempo) blijven daar; de rest
  // leeft hier. Zie lib/exercise-params.ts (itemColumnsFromParams).
  params      Json?

  tenant   Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  template WorkoutTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  day      WorkoutDay?     @relation(fields: [dayId], references: [id], onDelete: Cascade)
  exercise Exercise        @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([templateId])
  @@index([dayId])
  @@index([exerciseId])
}

model AssignedWorkout {
  id         String   @id @default(cuid())
  tenantId   String
  userId     String // MEMBER aan wie het schema is toegewezen
  templateId String? // lid-specifieke kloon (nullable wanneer handmatig gebouwd)
  sourceTemplateId String? // herkomst-library-template (voor het owner-overzicht)
  customName String? // naam bij handmatig opgebouwd schema
  createdAt  DateTime @default(now())

  // --- Levenscyclus / planning ---
  status        AssignmentStatus @default(PUBLISHED)
  availableFrom DateTime? // zichtbaarheidspoort; null/verleden = nu zichtbaar
  startDate     DateTime? // ingangsdatum (informatief)
  endDate       DateTime? // einddatum (optioneel; verlopen = niet meer actief)
  trainerMessage String? // persoonlijke boodschap van de trainer
  publishedAt   DateTime? // moment van publiceren
  assignedById  String? // User.id van de toewijzende owner/admin
  notifiedAt    DateTime? // meldingen verstuurd (voorkomt dubbele meldingen)
  seenAt        DateTime? // lid heeft het schema voor het eerst geopend ("Nieuw")

  // --- Zelf-gebouwd lid-schema (origin=MEMBER) ---
  // De `status` hierboven blijft de zichtbaarheidspoort; `memberStatus` draagt de
  // aparte review-/gebruik-levenscyclus. Null bij coach-schema's.
  origin        AssignmentOrigin    @default(COACH)
  memberStatus  MemberSchemaStatus?
  submittedAt   DateTime? // lid diende in ter controle
  reviewedAt    DateTime? // coach keurde goed/af
  reviewedById  String? // User.id van de beoordelende coach/owner
  reviewNote    String? // coach-feedback / afwijsreden (zichtbaar voor het lid)
  goal          SchemaRequestGoal? // trainingsdoel dat het lid koos
  focusNote     String? // vrije focus/voorkeur van het lid
  frameworkId   String? // kader waaronder het lid dit bouwde (informatief)

  // --- Master ↔ persoonlijke kopie (3-weg-diff) ---
  // De persoonlijke kopie (`template`) wordt bij toewijzen gekloond van de master
  // (`sourceTemplateId`). `baselineSnapshot` legt de master-staat op koppel-/
  // sync-moment vast: diff(kopie, baseline) = persoonlijke aanpassingen,
  // diff(master, baseline) = master-wijzigingen sinds sync. Zie lib/schema-diff.ts.
  baselineSnapshot Json? // genormaliseerde master-snapshot op koppel-/sync-moment
  masterSyncedAt   DateTime? // laatst erkende master-staat (master.updatedAt)

  tenant   Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  template WorkoutTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([userId])
  @@index([tenantId, userId, status])
  @@index([status, availableFrom])
  @@index([sourceTemplateId])
  @@index([tenantId, origin, memberStatus])
}

// Web-push-abonnement van één gebruiker/apparaat (PushSubscription API). Tenant-
// scoped (RLS); een lid kan meerdere apparaten registreren. Verlopen endpoints
// (410/404 bij verzenden) worden opgeruimd in lib/push.ts.
model PushSubscription {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
}

// Native push-device-token (APNs op iOS; voorbereid op FCM/Android). Tenant-scoped
// + RLS (zoals PushSubscription). Dode tokens (BadDeviceToken/Unregistered) worden
// opgeruimd bij verzenden in lib/push-apns.ts.
model NativePushToken {
  id         String   @id @default(cuid())
  tenantId   String
  userId     String
  platform   String // "ios" | "android"
  token      String   @unique
  createdAt  DateTime @default(now())
  lastUsedAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
}

model WorkoutSession {
  id        String    @id @default(cuid())
  tenantId  String
  userId    String
  startedAt DateTime  @default(now())
  endedAt   DateTime?
  // Trainingsbeleving (Workout Mood) — mood-key uit lib/workout-moods.ts.
  // NULL = het lid heeft (nog) geen beleving gekozen. One-tap na afronden.
  mood      String?

  // Automatische sessie-timeout (5 uur): gezet zodra een open sessie automatisch
  // is afgesloten omdat hij te lang openstond. `endedAt` wordt dan gecapt op
  // startedAt + 5u. `autoStopNotified` maakt de eenmalige "automatisch gestopt"-
  // melding idempotent (patroon van AssignedWorkout.notifiedAt/seenAt).
  autoStoppedAt    DateTime?
  autoStopNotified Boolean   @default(false)

  // Sessie-scoped aanpassingen die het template NIET muteren: overgeslagen
  // oefeningen + gekozen alternatieven. Vorm:
  // { skipped: string[], subs: { from: string, to: string, name: string }[] }.
  // Puur read-time toegepast (zie app/member/schema/active/page.tsx).
  overrides Json?

  // Gekozen trainingsdag binnen het schema (je doet één dag per sessie). NULL =
  // heel schema / één-dag-schema (backward compatible). Verwijst naar WorkoutDay
  // van het gekozen template; puur read-time gebruikt om de actieve sessie tot die
  // dag te filteren. Geen FK-relatie → overleeft dagwijzigingen in het schema.
  dayId     String?

  // Trainer die deze sessie namens het lid heeft gedraaid (PT-sessie vastleggen).
  // NULL = het lid loggde zelf. Puur attributie/audit — géén FK (zoals
  // AssignedWorkout.assignedById); de naam wordt read-time opgelost. De sessie
  // blijft toe aan `userId` (het lid): stats/PR's/trofeeën tellen als het lid.
  conductedById String?

  tenant             Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  performanceEntries PerformanceEntry[]

  // Hoogste-churn tabel: per-lid queries filteren op (tenantId, userId) + sorteren
  // op startedAt (member-stats/metrics/history/timeout); owner-dashboards op
  // (tenantId, startedAt). De losse userId-index blijft voor de GDPR-export
  // (app/account/export) die alléén op userId filtert. De losse tenantId-index is
  // overbodig — beide composieten leiden met tenantId.
  @@index([userId])
  @@index([tenantId, userId, startedAt])
  @@index([tenantId, startedAt])
}

model PerformanceEntry {
  id         String  @id @default(cuid())
  tenantId   String
  sessionId  String
  exerciseId String
  setNumber  Int
  reps       Int
  weightKg   Float
  notes      String?
  // Type-specifieke logwaarden (houdtijd/tijd/afstand/intensiteit/…). reps en
  // weightKg blijven de kolommen voor kracht (1RM/volume/PR ongewijzigd); overige
  // types loggen hier. Zie lib/exercise-params.ts (logColumnsFromParams).
  params     Json?

  tenant   Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  session  WorkoutSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  exercise Exercise       @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  // Eén entry per set binnen een sessie+oefening (maakt upsert mogelijk).
  @@unique([sessionId, exerciseId, setNumber])
  @@index([tenantId])
  @@index([sessionId])
  @@index([exerciseId])
}

// --- Platform-instellingen (Superadmin) ---
// Globale key/value-tabel (géén tenantId/RLS, zoals AuditLog/ExerciseCatalog/
// EmailTemplate): configureerbare platformwaarden die de Superadmin zonder
// redeploy kan wijzigen (bv. het support-e-mailadres). Nieuwe instelling =
// één key erbij; lezen/schrijven via lib/platform-settings.ts.
model PlatformSetting {
  key            String   @id
  value          String
  updatedById    String?
  updatedByEmail String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("platform_setting")
}
