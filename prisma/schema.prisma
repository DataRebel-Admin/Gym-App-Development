// GymRebel Prisma schema — zie CLAUDE.md voor architectuur-principes.
//
// Multitenant: élk model behalve Tenant heeft een `tenantId` + relatie naar
// Tenant en een @@index([tenantId]). RLS-policies (prompt 04) zorgen voor
// daadwerkelijke isolatie op DB-niveau.
//
// NB: het trainings-sessiemodel heet `WorkoutSession` (niet `Session`) om
// botsing met het Auth.js `Session`-model (prompt 03) te voorkomen.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // DIRECT_URL wordt gebruikt voor migraties wanneer DATABASE_URL een
  // connection pooler is (bv. Neon/Vercel Postgres).
  directUrl = env("DIRECT_URL")
}

enum Role {
  SUPERADMIN // platform-beheerder, transcendeert tenants (tenantId == null)
  TENANT_ADMIN // sportschooleigenaar/beheerder (voorheen OWNER)
  TENANT_STAFF // sportschoolmedewerker/coach (permissie-gestuurd, tenant-gebonden)
  TENANT_MEMBER // sporter (voorheen MEMBER)
}

enum TenantStatus {
  ACTIVE
  INACTIVE
}

enum Locale {
  NL
  EN
  FY
}

enum MachineType {
  CARDIO
  KRACHT
  VRIJE_GEWICHTEN
  OVERIG
}

// Moeilijkheidsgraad voor eigen (tenant-)oefeningen. Catalogus-oefeningen leiden
// hun niveau heuristisch af (zie lib/exercise.ts deriveDifficulty).
enum ExerciseDifficulty {
  BEGINNER
  GEMIDDELD
  GEVORDERD
}

enum Gender {
  MAN
  VROUW
  NON_BINAIR
  ONBEKEND
}

// Levenscyclus van een aan een lid toegewezen schema. Een lid kan meerdere
// toewijzingen hebben (bv. een actief schema + een gepland toekomstig schema);
// het lid ziet er telkens precies één — zie lib/member.ts (getAssignedSchema).
enum AssignmentStatus {
  DRAFT // concept — nog niet zichtbaar voor het lid
  SCHEDULED // gepland — wordt zichtbaar zodra availableFrom is bereikt
  PUBLISHED // live — zichtbaar voor het lid
  ARCHIVED // niet meer actief (handmatig of na einddatum)
}

// Soort herbruikbare template in de bibliotheek. SCHEMA = volledig trainingsschema
// (meerdere dagen); DAY = één herbruikbare trainingsdag (Push/Pull/Legs/…) die je
// als blok in een schema kunt invoegen ("Dag toevoegen vanuit template").
enum WorkoutTemplateKind {
  SCHEMA
  DAY
}

// Doel van een schema-aanvraag door een sporter.
enum SchemaRequestGoal {
  MUSCLE // spiermassa opbouwen
  WEIGHT_LOSS // afvallen
  CONDITION // conditie verbeteren
  REHAB // revalidatie
  STRENGTH // krachttraining
  OTHER // anders (zie beschrijving)
}

// Levenscyclus van een schema-aanvraag (sporter → coach → oplevering).
enum SchemaRequestStatus {
  NEW // ingediend, nog niet opgepakt
  IN_PROGRESS // coach is ermee bezig
  SCHEMA_CREATED // schema gemaakt, nog niet afgerond
  COMPLETED // afgerond (schema staat klaar voor het lid)
  REJECTED // afgewezen door de coach
  CANCELLED // geannuleerd door het lid
}

model Tenant {
  id          String   @id @default(cuid())
  slug        String   @unique // subdomein, bv. "fitpower"
  name        String
  logoUrl     String?
  accentColor String? // primaire kleur (hex), bv. "#E84B1F"
  secondaryColor String? // secundaire kleur (hex)
  faviconUrl  String?
  fontFamily  String? // optioneel; CSS font-family naam
  locale      Locale       @default(NL)
  status      TenantStatus @default(ACTIVE)
  aiEnabled   Boolean      @default(false)
  // --- Zakelijke gegevens (tenant-instellingen, owner) ---
  contactEmail String?
  contactPhone String?
  addressLine  String?
  postalCode   String?
  city         String?
  country      String?
  website      String?
  vatNumber    String? // BTW-nummer
  cocNumber    String? // KvK-nummer
  socials      Json? // { instagram, facebook, ... }
  openingHours Json? // { mon: "06:00-22:00", ... }
  deletedAt   DateTime? // soft-delete; null = actief bestaand
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  invitations       Invitation[]
  users             User[]
  machines          Machine[]
  exercises         Exercise[]
  templates         WorkoutTemplate[]
  workoutDays       WorkoutDay[]
  workoutItems      WorkoutExerciseItem[]
  assignedWorkouts  AssignedWorkout[]
  sessions          WorkoutSession[]
  performanceEntries PerformanceEntry[]
  aiUsages          AiUsage[]
  groupClasses      GroupClass[]
  classSessions     ClassSession[]
  classEnrollments  ClassEnrollment[]
  notifications     Notification[]
  pushSubscriptions PushSubscription[]
  measurements      Measurement[]
  measurementPhotos MeasurementPhoto[]
  memberGoals       MemberGoal[]
  schemaRequests    SchemaRequest[]
  coachNotes        CoachNote[]
  coachAssignments  CoachAssignment[]
}

// In-app melding voor één gebruiker. `tenantId` is nullable zodat ook een
// SUPERADMIN (zonder tenant) een melding kan krijgen. Beveiliging loopt via de
// verplichte `userId`-filter in alle queries (zoals de andere user-scoped data).
model Notification {
  id        String    @id @default(cuid())
  tenantId  String?
  userId    String
  category  String // bv. "schemas", "security" — matcht een meldingscategorie
  title     String
  body      String?
  link      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([userId, createdAt])
  @@index([tenantId])
}

// --- Body Composition & Progress Tracking ---

// Herkomst van een meting. MANUAL = handmatig; de rest is integratie-prep
// (device-sync), nog niet actief — zie Measurement.externalId/raw.
enum MeasurementSource {
  MANUAL
  INBODY
  TANITA
  EVOLT
  GARMIN
  APPLE_HEALTH
  GOOGLE_FIT
}

enum PhotoPose {
  FRONT
  SIDE
  BACK
}

enum GoalMetric {
  WEIGHT
  BODY_FAT
  MUSCLE_MASS
  BMI
  WAIST
}

// Eén lichaamsmeting op een moment. Historisch — nooit overschrijven. Velden
// nullable zodat een trainer alleen invult wat de weegschaal levert. `extra`
// (Json) houdt de structuur uitbreidbaar voor toekomstige meetwaarden.
model Measurement {
  id           String            @id @default(cuid())
  tenantId     String
  userId       String // het lid
  recordedById String? // trainer/owner die de meting invoerde
  measuredAt   DateTime
  notes        String?
  source       MeasurementSource @default(MANUAL)
  externalId   String? // integratie-prep: device-record-id
  raw          Json? // integratie-prep: ruwe device-payload
  // Lichaamssamenstelling
  weightKg     Float?
  bodyFatPct   Float?
  muscleMassKg Float?
  fatMassKg    Float?
  bmi          Float?
  waterPct     Float?
  boneMassKg   Float?
  visceralFat  Float?
  bmr          Int?
  metabolicAge Int?
  // Omtrek (cm)
  chestCm      Float?
  waistCm      Float?
  hipsCm       Float?
  neckCm       Float?
  armLeftCm    Float?
  armRightCm   Float?
  thighLeftCm  Float?
  thighRightCm Float?
  calfLeftCm   Float?
  calfRightCm  Float?
  extra        Json? // extra/toekomstige meetwaarden
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  tenant Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User               @relation("MemberMeasurements", fields: [userId], references: [id], onDelete: Cascade)
  photos MeasurementPhoto[]

  @@index([tenantId])
  @@index([userId, measuredAt])
}

model MeasurementPhoto {
  id            String    @id @default(cuid())
  tenantId      String
  measurementId String
  pose          PhotoPose
  url           String
  createdAt     DateTime  @default(now())

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  measurement Measurement @relation(fields: [measurementId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([measurementId])
}

// Persoonlijk doel per metric, ingesteld door de trainer. Historisch (meerdere
// mogen bestaan); de app toont het meest recente actieve doel per metric.
model MemberGoal {
  id          String     @id @default(cuid())
  tenantId    String
  userId      String
  metric      GoalMetric
  startValue  Float?
  targetValue Float
  targetDate  DateTime?
  createdById String?
  achievedAt  DateTime?
  createdAt   DateTime   @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation("MemberGoals", fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId, metric])
}

// Eén rij per AI-assistent-vraag — voor rate-limiting (per lid/dag) en
// kostenmonitoring (per tenant/maand).
model AiUsage {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([userId, createdAt])
}

// --- Groepslessen / rooster (prompt 12) ---

model GroupClass {
  id              String   @id @default(cuid())
  tenantId        String
  name            String
  description     String?
  instructorName  String?
  maxParticipants Int      @default(12)
  createdAt       DateTime @default(now())

  tenant   Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sessions ClassSession[]

  @@index([tenantId])
}

model ClassSession {
  id       String   @id @default(cuid())
  tenantId String
  classId  String
  startsAt DateTime
  endsAt   DateTime
  location String?

  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  groupClass  GroupClass        @relation(fields: [classId], references: [id], onDelete: Cascade)
  enrollments ClassEnrollment[]

  @@index([tenantId, startsAt])
  @@index([classId])
}

model ClassEnrollment {
  id         String   @id @default(cuid())
  tenantId   String
  sessionId  String
  userId     String
  enrolledAt DateTime @default(now())

  tenant  Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  session ClassSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Eén aanmelding per lid per sessie.
  @@unique([sessionId, userId])
  @@index([tenantId])
  @@index([userId])
}

model User {
  id            String    @id @default(cuid())
  email         String
  emailVerified DateTime? // vereist door de Auth.js adapter
  name          String?
  image         String? // vereist door de Auth.js adapter
  role          Role      @default(TENANT_MEMBER)
  active        Boolean   @default(true) // account geactiveerd/gedeactiveerd
  archivedAt    DateTime? // gearchiveerd lid (uit actieve roster, niet verwijderd)
  // --- Profiel (accountinstellingen) ---
  firstName     String?
  lastName      String?
  jobTitle      String?
  phone         String?
  birthDate     DateTime? // geboortedatum (o.a. via bulk-import)
  gender        Gender? // geslacht (o.a. via bulk-import)
  memberNumber  String? // sportschool-lidnummer (uniek per tenant; o.a. via bulk-import)
  timezone      String? // IANA, bv. "Europe/Amsterdam"
  locale        Locale? // persoonlijke taal (override op tenant.locale)
  preferences   Json? // persoonlijke voorkeuren (thema, dichtheid, datum/tijd-notatie, …)
  notificationPrefs Json? // per categorie × kanaal (e-mail/in-app/push)
  // Per-medewerker permissie-override (TENANT_STAFF). null = role-default.
  // Vorm: Record<Permission, boolean> — zie lib/rbac.ts.
  permissions   Json?
  consents      Json? // privacy-toestemmingen (bv. marketing)
  deletionRequestedAt DateTime? // verzoek tot accountverwijdering
  // --- Beveiliging ---
  passwordHash     String? // bcrypt; null = alleen magic-link
  twoFactorSecret  String? // base32 TOTP-secret (pending of actief)
  twoFactorEnabled Boolean   @default(false)
  sessionsValidFrom DateTime? // sessies vóór dit moment zijn ongeldig (logout overal)
  // E-mailwijziging met verificatie.
  pendingEmail       String?
  emailChangeToken   String?   @unique
  emailChangeExpires DateTime?
  tenantId      String? // NULL voor SUPERADMIN (transcendeert tenants)
  // Persoonlijke owner-dashboard indeling (widget-volgorde + zichtbaarheid).
  // null = standaard-layout. Geen RLS-impact (kolom op bestaand model).
  dashboardLayout Json?
  createdAt     DateTime  @default(now())

  tenant           Tenant?           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignedWorkouts AssignedWorkout[]
  sessions         WorkoutSession[]
  classEnrollments ClassEnrollment[]
  accounts         Account[] // Auth.js (OAuth, later)
  authSessions     Session[] // Auth.js DB-sessies (we gebruiken jwt, maar model vereist)
  userSessions     UserSession[] // device/sessie-registratie
  notifications    Notification[]
  pushSubscriptions PushSubscription[]
  measurements     Measurement[] @relation("MemberMeasurements")
  goals            MemberGoal[]  @relation("MemberGoals")
  schemaRequests   SchemaRequest[]
  coachNotes         CoachNote[] @relation("CoachNoteMember") // notities óver dit lid
  authoredCoachNotes CoachNote[] @relation("CoachNoteAuthor") // notities geschreven door deze medewerker
  coachingMembers    CoachAssignment[] @relation("CoachAssignmentCoach") // leden die deze coach begeleidt
  assignedCoaches    CoachAssignment[] @relation("CoachAssignmentMember") // coaches van dit lid

  // Email is uniek per tenant (niet globaal): twee tenants mogen hetzelfde
  // emailadres hebben. De tenant-scoped adapter scoped lookups hierop.
  // SUPERADMIN (tenantId NULL) is globaal uniek via een partial index (zie migratie).
  @@unique([tenantId, email])
  // Lidnummer uniek per tenant (NULLs mogen meermaals voorkomen in Postgres).
  @@unique([tenantId, memberNumber])
  @@index([tenantId])
}

// Uitnodiging om als gebruiker bij een tenant te komen (e-mail + token).
model Invitation {
  id          String    @id @default(cuid())
  tenantId    String
  email       String
  role        Role      @default(TENANT_MEMBER)
  token       String    @unique
  expiresAt   DateTime
  invitedById String? // User.id van de uitnodiger (superadmin of tenant-admin)
  acceptedAt  DateTime?
  createdAt   DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([token])
}

// Audit log van beheertaken. Bewust GEEN FK naar Tenant/User (forensisch: blijft
// bestaan na verwijdering). tenantId NULL = platform-niveau (bv. tenant aanmaken).
model AuditLog {
  id         String      @id @default(cuid())
  actorId    String?
  actorEmail String?
  actorRole  Role?
  tenantId   String?
  action     String // bv. "tenant.create", "branding.update", "user.role.change"
  category   String? // afgeleid van de action-prefix (user/schema/exercise/tenant/auth)
  status     AuditStatus @default(SUCCESS)
  targetType String?
  targetId   String?
  oldValue   Json? // staat vóór de wijziging (indien relevant)
  newValue   Json? // staat ná de wijziging (indien relevant)
  ipAddress  String? // geanonimiseerd (laatste octet → 0 / IPv6 ingekort)
  userAgent  String? // browser/device
  metadata   Json?
  createdAt  DateTime    @default(now())

  @@index([tenantId, createdAt])
  @@index([action, createdAt])
  @@index([tenantId, category, createdAt])
  @@index([actorId, createdAt])
}

enum AuditStatus {
  SUCCESS
  FAILED
}

// --- E-mailtemplatebeheer (Superadmin) ---
// Globale platform-tabel (géén tenantId/RLS, zoals AuditLog/ExerciseCatalog): de
// content is bron voor álle tenants; de gebrande shell + branding worden per
// tenant runtime toegevoegd (zie lib/email/template-render.ts). Editbaar concept
// + gepubliceerde snapshot; de app verstuurt de gepubliceerde versie en valt
// terug op de hardgecodeerde composers in lib/email/messages.ts.

enum EmailTemplateStatus {
  DRAFT // er staan onuitgegeven concept-wijzigingen klaar
  PUBLISHED // concept == gepubliceerde inhoud (live)
}

model EmailTemplate {
  id      String @id @default(cuid())
  key     String // bv. "magicLink", "invite", "welcome" — zie lib/email/template-defaults.ts
  locale  Locale @default(NL)

  // Werk-concept (autosave):
  subject   String
  preheader String?
  bodyHtml  String  @db.Text

  // Gepubliceerde snapshot — dít verstuurt de app:
  publishedSubject   String?
  publishedPreheader String?
  publishedBodyHtml  String?   @db.Text
  publishedAt        DateTime?

  status         EmailTemplateStatus @default(DRAFT)
  updatedById    String?
  updatedByEmail String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  versions EmailTemplateVersion[]

  @@unique([key, locale])
}

model EmailTemplateVersion {
  id          String        @id @default(cuid())
  templateId  String
  template    EmailTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  subject     String
  preheader   String?
  bodyHtml    String        @db.Text
  note        String? // opmerking van de auteur bij publicatie
  authorId    String?
  authorEmail String?
  createdAt   DateTime      @default(now())

  @@index([templateId, createdAt])
}

// --- Auth.js (NextAuth v5) infra-tabellen ---
// Géén tenantId/RLS: dit zijn framework-tabellen, geen tenant-business-data.
// De Prisma-adapter maakt deze rijen aan zonder tenant-context.

// Device-/sessie-registratie voor "actieve sessies" + op afstand uitloggen.
model UserSession {
  id         String    @id @default(cuid())
  userId     String
  userAgent  String?
  ip         String?
  createdAt  DateTime  @default(now())
  lastSeenAt DateTime  @default(now())
  revokedAt  DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Machine {
  id             String      @id @default(cuid())
  tenantId       String
  name           String
  type           MachineType @default(OVERIG)
  description    String?
  instructionsMd String?     @db.Text
  videoUrl       String?
  imageUrl       String?
  qrToken        String      @unique
  createdAt      DateTime    @default(now())

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  exercises Exercise[]

  @@index([tenantId])
}

model Exercise {
  id           String  @id @default(cuid())
  tenantId     String
  name         String
  description  String?
  targetMuscle String?
  machineId    String? // nullable: lichaamsgewicht-oefeningen hebben geen machine
  catalogId    String? // optioneel: link naar de globale ExerciseCatalog (bron van media/instructies)

  // Oefeningstype (code-registry, zie lib/exercise-types.ts) — bepaalt wélke
  // parameters relevant zijn (sets/reps/gewicht vs. tijd/afstand/intensiteit…).
  // Bewust een String (geen enum): een nieuw type vereist geen DB-migratie.
  exerciseType String @default("strength")

  // --- Eigen-oefening content (alleen gevuld bij catalogId == null) ---
  // Een "eigen oefening" is een tenant-Exercise zonder catalogus-koppeling; deze
  // velden vervangen dan de catalogus als bron van media/instructies/metadata.
  // Bij catalogus-gekoppelde oefeningen blijven ze NULL (catalogus is leidend).
  muscleGroups     String[]            @default([]) // extra spiergroepen (naast targetMuscle)
  category         String? // categorie (bv. "Kracht", "Cardio")
  difficulty       ExerciseDifficulty? // moeilijkheidsgraad (expliciet voor eigen oefeningen)
  equipment        String? // benodigd materiaal
  tags             String[]            @default([]) // vrije labels
  executionMd      String?  @db.Text // Uitvoering (Markdown)
  coachingTipsMd   String?  @db.Text // Coachingtips (Markdown)
  commonMistakesMd String?  @db.Text // Veelgemaakte fouten (Markdown)
  notesMd          String?  @db.Text // Opmerkingen (Markdown)
  imageUrls        String[]            @default([]) // één of meerdere afbeeldingen
  videoUrl         String? // optionele videolink (YouTube/Vimeo)
  archivedAt       DateTime? // soft-archive: verbergt uit pickers, schema's blijven werken

  tenant             Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  machine            Machine?              @relation(fields: [machineId], references: [id], onDelete: SetNull)
  catalog            ExerciseCatalog?      @relation(fields: [catalogId], references: [id], onDelete: SetNull)
  workoutItems       WorkoutExerciseItem[]
  performanceEntries PerformanceEntry[]

  @@index([tenantId])
  @@index([machineId])
  @@index([catalogId])
}

// Globale oefeningen-catalogus (externe dataset, 1.324 records). NIET tenant-scoped
// en GEEN RLS — net als Tenant/Auth-tabellen. Dit is de bron van waarheid voor
// media, spiergroepen en (meertalige) instructies; tenants cureren hun eigen
// selectie via Exercise.catalogId. Gevuld door scripts/import-exercises.mjs.
model ExerciseCatalog {
  id               String   @id
  name             String
  category         String
  bodyPart         String   @map("body_part")
  equipment        String
  target           String
  muscleGroup      String?  @map("muscle_group")
  secondaryMuscles String[] @map("secondary_muscles")
  instructions     Json // { en, es, it, tr, nl } — vrije tekst per taal
  instructionSteps Json?    @map("instruction_steps") // { en: [...], ..., nl: [...] }
  imageUrl         String   @map("image_url")
  gifUrl           String   @map("gif_url")
  createdAt        DateTime @default(now()) @map("created_at")

  exercises Exercise[]

  @@index([category])
  @@index([equipment])
  @@index([target])
  @@map("exercise_catalog")
}

// Aanvraag van een sporter voor een (nieuw/aangepast) trainingsschema. Tenant-
// scoped business-data (RLS, zie prisma/sql/rls.sql). Vormt samen met de
// schema-toewijzing een complete workflow van aanvraag tot oplevering.
model SchemaRequest {
  id                   String              @id @default(cuid())
  tenantId             String
  userId               String // sporter die de aanvraag indient
  goal                 SchemaRequestGoal
  description          String?             @db.Text // vrije toelichting op het doel
  preferredStart       DateTime? // gewenste startdatum (optioneel)
  notes                String?             @db.Text // extra opmerkingen
  status               SchemaRequestStatus @default(NEW)
  handledById          String? // User.id van de owner/admin die de aanvraag oppakte
  resolvedAssignmentId String? // gekoppelde AssignedWorkout bij oplevering (optioneel)
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@index([userId])
}

// Coachnotitie over een lid, geschreven door een medewerker/eigenaar. Tenant-
// scoped business-data (RLS, zie prisma/sql/rls.sql).
model CoachNote {
  id        String   @id @default(cuid())
  tenantId  String
  memberId  String // lid waarover de notitie gaat
  authorId  String // medewerker/eigenaar die de notitie schreef
  body      String   @db.Text
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  member User   @relation("CoachNoteMember", fields: [memberId], references: [id], onDelete: Cascade)
  author User   @relation("CoachNoteAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([tenantId, memberId])
  @@index([authorId])
}

// Koppeling tussen een coach (medewerker/eigenaar) en een lid dat hij/zij begeleidt.
// Many-to-many: een lid kan meerdere coaches hebben en omgekeerd. Tenant-scoped
// business-data (RLS, zie prisma/sql/rls.sql).
model CoachAssignment {
  id           String   @id @default(cuid())
  tenantId     String
  coachId      String // medewerker/eigenaar die begeleidt
  memberId     String // het lid
  assignedById String? // wie de koppeling maakte
  createdAt    DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  coach  User   @relation("CoachAssignmentCoach", fields: [coachId], references: [id], onDelete: Cascade)
  member User   @relation("CoachAssignmentMember", fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([tenantId, coachId, memberId])
  @@index([tenantId, coachId])
  @@index([tenantId, memberId])
}

model WorkoutTemplate {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  isLibrary   Boolean  @default(false) // true = zichtbaar als herbruikbare template
  kind        WorkoutTemplateKind @default(SCHEMA) // SCHEMA = volledig schema; DAY = herbruikbare dag
  coachNote   String?  @db.Text // coach-notitie op schema-niveau (zichtbaar voor het lid)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant           Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  days             WorkoutDay[]
  items            WorkoutExerciseItem[]
  assignedWorkouts AssignedWorkout[]

  @@index([tenantId])
}

// Trainingsdag binnen een schema (schema → dagen → oefeningen).
model WorkoutDay {
  id         String @id @default(cuid())
  tenantId   String
  templateId String
  order      Int    @default(0)
  name       String @default("Dag 1")
  notes      String? // coach-notitie op dag-niveau (zichtbaar voor het lid)

  tenant   Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  template WorkoutTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  items    WorkoutExerciseItem[]

  @@index([tenantId])
  @@index([templateId])
}

model WorkoutExerciseItem {
  id          String @id @default(cuid())
  tenantId    String
  templateId  String
  exerciseId  String
  dayId       String? // trainingsdag binnen het schema (na backfill altijd gezet)
  order       Int    @default(0)
  sets        Int    @default(3)
  reps        Int    @default(10)
  restSeconds Int    @default(60)
  weightKg    Float? // streefgewicht (optioneel)
  tempo       String? // tempo-cadans, bv. "3-1-1" (optioneel)
  notes       String? // opmerking bij de oefening (optioneel)
  // Type-specifieke doel-parameters (tijd/afstand/intensiteit/…). Velden die op
  // een kolom mappen (sets/reps/restSeconds/weightKg/tempo) blijven daar; de rest
  // leeft hier. Zie lib/exercise-params.ts (itemColumnsFromParams).
  params      Json?

  tenant   Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  template WorkoutTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  day      WorkoutDay?     @relation(fields: [dayId], references: [id], onDelete: Cascade)
  exercise Exercise        @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([templateId])
  @@index([dayId])
  @@index([exerciseId])
}

model AssignedWorkout {
  id         String   @id @default(cuid())
  tenantId   String
  userId     String // MEMBER aan wie het schema is toegewezen
  templateId String? // lid-specifieke kloon (nullable wanneer handmatig gebouwd)
  sourceTemplateId String? // herkomst-library-template (voor het owner-overzicht)
  customName String? // naam bij handmatig opgebouwd schema
  createdAt  DateTime @default(now())

  // --- Levenscyclus / planning ---
  status        AssignmentStatus @default(PUBLISHED)
  availableFrom DateTime? // zichtbaarheidspoort; null/verleden = nu zichtbaar
  startDate     DateTime? // ingangsdatum (informatief)
  endDate       DateTime? // einddatum (optioneel; verlopen = niet meer actief)
  trainerMessage String? // persoonlijke boodschap van de trainer
  publishedAt   DateTime? // moment van publiceren
  assignedById  String? // User.id van de toewijzende owner/admin
  notifiedAt    DateTime? // meldingen verstuurd (voorkomt dubbele meldingen)
  seenAt        DateTime? // lid heeft het schema voor het eerst geopend ("Nieuw")

  // --- Master ↔ persoonlijke kopie (3-weg-diff) ---
  // De persoonlijke kopie (`template`) wordt bij toewijzen gekloond van de master
  // (`sourceTemplateId`). `baselineSnapshot` legt de master-staat op koppel-/
  // sync-moment vast: diff(kopie, baseline) = persoonlijke aanpassingen,
  // diff(master, baseline) = master-wijzigingen sinds sync. Zie lib/schema-diff.ts.
  baselineSnapshot Json? // genormaliseerde master-snapshot op koppel-/sync-moment
  masterSyncedAt   DateTime? // laatst erkende master-staat (master.updatedAt)

  tenant   Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  template WorkoutTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([userId])
  @@index([tenantId, userId, status])
  @@index([status, availableFrom])
  @@index([sourceTemplateId])
}

// Web-push-abonnement van één gebruiker/apparaat (PushSubscription API). Tenant-
// scoped (RLS); een lid kan meerdere apparaten registreren. Verlopen endpoints
// (410/404 bij verzenden) worden opgeruimd in lib/push.ts.
model PushSubscription {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
}

model WorkoutSession {
  id        String    @id @default(cuid())
  tenantId  String
  userId    String
  startedAt DateTime  @default(now())
  endedAt   DateTime?

  tenant             Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  performanceEntries PerformanceEntry[]

  @@index([tenantId])
  @@index([userId])
}

model PerformanceEntry {
  id         String  @id @default(cuid())
  tenantId   String
  sessionId  String
  exerciseId String
  setNumber  Int
  reps       Int
  weightKg   Float
  notes      String?
  // Type-specifieke logwaarden (houdtijd/tijd/afstand/intensiteit/…). reps en
  // weightKg blijven de kolommen voor kracht (1RM/volume/PR ongewijzigd); overige
  // types loggen hier. Zie lib/exercise-params.ts (logColumnsFromParams).
  params     Json?

  tenant   Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  session  WorkoutSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  exercise Exercise       @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  // Eén entry per set binnen een sessie+oefening (maakt upsert mogelijk).
  @@unique([sessionId, exerciseId, setNumber])
  @@index([tenantId])
  @@index([sessionId])
  @@index([exerciseId])
}
